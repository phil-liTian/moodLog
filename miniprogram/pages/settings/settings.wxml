<view class="page">
  <view class="section">
    <view class="section-title">账号与安全</view>
    <view class="menu-item"><text class="menu-text">隐私设置</text><switch checked="{{settings.privacyLevel === 'cloud'}}" color="#8B5CF6" bindchange="togglePrivacy"/></view>
    <view class="menu-item"><text class="menu-text">云端同步</text><switch checked="{{settings.dataSyncEnabled}}" color="#8B5CF6" bindchange="toggleSync"/></view>
  </view>
  <view class="section">
    <view class="section-title">AI 功能</view>
    <view class="menu-item"><text class="menu-text">AI 月度总结</text><switch checked="{{settings.aiAnalysisEnabled}}" color="#8B5CF6" bindchange="toggleAI"/></view>
    <view class="menu-item"><text class="menu-text">每日提醒</text><switch checked="{{settings.reminderEnabled}}" color="#8B5CF6" bindchange="toggleReminder"/></view>
  </view>
  <view class="section">
    <view class="section-title">数据管理</view>
    <view class="menu-item" bindtap="exportData"><text class="menu-text">导出数据</text><text class="arrow">›</text></view>
    <view class="menu-item" bindtap="clearData"><text class="menu-text">清空数据</text><text class="arrow">›</text></view>
  </view>
</view>