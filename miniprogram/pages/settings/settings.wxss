.page { min-height: 100vh; background: #F8FAFC; }
.section { background: #fff; margin: 20px; border-radius: 16px; padding: 20px; }
.section-title { font-size: 14px; color: #94A3B8; margin-bottom: 16px; }
.menu-item { display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #F1F5F9; }
.menu-item:last-child { border-bottom: none; }
.menu-text { font-size: 15px; color: #1E293B; }
.arrow { font-size: 18px; color: #CBD5E1; }