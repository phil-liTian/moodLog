/* 首页样式 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #8B5CF6 0%, #F8FAFC 30%);
  background-attachment: fixed;
  padding-bottom: 120px;
}

/* 顶部用户区 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 80px 20px 20px;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 12px;
}

.avatar {
  width: 48px;
  height: 48px;
  border-radius: 24px;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24px;
}

.greeting {
  display: flex;
  flex-direction: column;
}

.time-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

.name {
  font-size: 20px;
  font-weight: 600;
  color: #fff;
}

.settings-btn {
  width: 36px;
  height: 36px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn .icon {
  font-size: 18px;
}

/* 记录卡片 */
.record-card {
  margin: 20px;
  padding: 24px;
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 4px 20px rgba(139, 92, 246, 0.15);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-content {
  display: flex;
  align-items: center;
  gap: 16px;
}

.record-icon {
  width: 56px;
  height: 56px;
  min-width: 56px;
  border-radius: 28px;
  background: linear-gradient(135deg, #8B5CF6 0%, #A78BFA 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
}

.record-text {
  display: flex;
  flex-direction: column;
}

.record-title {
  font-size: 18px;
  font-weight: 600;
  color: #1E293B;
}

.record-desc {
  font-size: 14px;
  color: #64748B;
  margin-top: 4px;
}

.record-action .arrow {
  font-size: 24px;
  color: #CBD5E1;
}

/* 概览区域 */
.overview-section {
  margin: 0 20px;
  padding: 20px;
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
}

.month-picker {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  background: #F1F5F9;
  border-radius: 16px;
  font-size: 14px;
  color: #64748B;
}

.month-picker .arrow {
  font-size: 10px;
}

/* 月份选择器 */
.month-picker-panel {
  background: #F8FAFC;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.picker-btn {
  font-size: 24px;
  color: #8B5CF6;
  padding: 0 12px;
}

.picker-year {
  font-size: 16px;
  font-weight: 600;
  color: #1E293B;
}

.picker-months {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
}

.picker-month {
  padding: 8px;
  text-align: center;
  border-radius: 8px;
  font-size: 14px;
  color: #64748B;
  background: #fff;
}

.picker-month.active {
  background: #8B5CF6;
  color: #fff;
}

/* 快捷统计 */
.quick-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 20px;
  padding-top: 20px;
  border-top: 1px solid #E2E8F0;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 24px;
  font-weight: 700;
  color: #8B5CF6;
}

.stat-label {
  font-size: 12px;
  color: #94A3B8;
  margin-top: 4px;
}

/* 关键词区域 */
.keywords-section {
  margin: 20px;
  padding: 20px;
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

.keywords-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.keyword-tag {
  padding: 6px 12px;
  background: linear-gradient(135deg, #F3E8FF 0%, #EDE9FE 100%);
  border-radius: 16px;
  color: #7C3AED;
}

/* 最近记录 */
.recent-section {
  margin: 0 20px;
  padding: 20px;
  background: #FFFFFF;
  border-radius: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}

.more-btn {
  font-size: 14px;
  color: #8B5CF6;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.record-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 12px;
  background: #F8FAFC;
  border-radius: 12px;
}

.record-emoji {
  width: 40px;
  height: 40px;
  min-width: 40px;
  border-radius: 20px;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.record-date {
  font-size: 12px;
  color: #94A3B8;
}

.record-mood {
  font-size: 14px;
  font-weight: 500;
  color: #1E293B;
  margin-top: 2px;
}

.record-content-preview {
  font-size: 13px;
  color: #64748B;
  margin-top: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 200px;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60px 20px;
}

.empty-icon {
  font-size: 64px;
  margin-bottom: 16px;
}

.empty-text {
  font-size: 18px;
  font-weight: 600;
  color: #1E293B;
}

.empty-hint {
  font-size: 14px;
  color: #94A3B8;
  margin-top: 8px;
}