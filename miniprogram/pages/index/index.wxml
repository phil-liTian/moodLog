<!--index.wxml-->
<view class="page">
  <!-- 顶部用户区 -->
  <view class="header">
    <view class="user-info">
      <view class="avatar">{{userGreeting.avatar}}</view>
      <view class="greeting">
        <text class="time-text">{{userGreeting.timeText}}</text>
        <text class="name">{{userGreeting.name}}</text>
      </view>
    </view>
    <view class="settings-btn" bindtap="goToSettings">
      <text class="icon">⚙️</text>
    </view>
  </view>

  <!-- 记录入口卡片 -->
  <view class="record-card" bindtap="goToRecord">
    <view class="record-content">
      <view class="record-icon">{{todayRecord ? todayRecord.emoji : '📝'}}</view>
      <view class="record-text">
        <text class="record-title">{{todayRecord ? '今日已记录' : '记录今日心情'}}</text>
        <text class="record-desc" wx:if="{{todayRecord}}">{{todayRecord.moodName}}</text>
        <text class="record-desc" wx:else>点击开始记录</text>
      </view>
    </view>
    <view class="record-action">
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 本月概览 -->
  <view class="overview-section">
    <view class="section-header">
      <text class="section-title">本月心情概览</text>
      <view class="month-picker" bindtap="toggleMonthPicker">
        <text>{{currentYear}}年{{currentMonth}}月</text>
        <text class="arrow">▼</text>
      </view>
    </view>

    <!-- 月份选择器 -->
    <view class="month-picker-panel" wx:if="{{showMonthPicker}}">
      <view class="picker-header">
        <text class="picker-btn" bindtap="prevYear">‹</text>
        <text class="picker-year">{{pickerYear}}</text>
        <text class="picker-btn" bindtap="nextYear">›</text>
      </view>
      <view class="picker-months">
        <view 
          class="picker-month {{pickerMonth === index + 1 ? 'active' : ''}}" 
          wx:for="{{12}}" 
          wx:key="index"
          data-month="{{index + 1}}"
          bindtap="selectMonth"
        >{{index + 1}}月</view>
      </view>
    </view>

    <!-- 心情日历 -->
    <mood-calendar
      year="{{currentYear}}"
      month="{{currentMonth}}"
      moodData="{{monthStats.moodCalendar}}"
      bind:dayClick="onDayClick"
    />

    <!-- 快捷统计 -->
    <view class="quick-stats">
      <view class="stat-item">
        <text class="stat-value">{{monthStats.totalRecords}}</text>
        <text class="stat-label">记录天数</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{monthStats.avgMoodScore}}</text>
        <text class="stat-label">平均心情</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{topMoodEmoji}}</text>
        <text class="stat-label">最常心情</text>
      </view>
    </view>
  </view>

  <!-- 本月关键词 -->
  <view class="keywords-section" wx:if="{{monthStats.topTags.length > 0}}">
    <view class="section-header">
      <text class="section-title">本月关键词</text>
    </view>
    <view class="keywords-list">
      <view 
        class="keyword-tag" 
        wx:for="{{monthStats.topTags}}" 
        wx:key="tag"
        style="font-size: {{12 + item.weight / 10}}px; opacity: {{0.6 + item.weight / 200}}"
      >{{item.tag}}</view>
    </view>
  </view>

  <!-- 最近记录 -->
  <view class="recent-section" wx:if="{{recentRecords.length > 0}}">
    <view class="section-header">
      <text class="section-title">最近记录</text>
      <text class="more-btn" bindtap="goToStatistics">更多 ›</text>
    </view>
    <view class="record-list">
      <view 
        class="record-item" 
        wx:for="{{recentRecords}}" 
        wx:key="recordId"
        data-id="{{item.recordId}}"
        bindtap="goToDetail"
      >
        <view class="record-emoji">{{item.emoji}}</view>
        <view class="record-info">
          <text class="record-date">{{item.dateText}}</text>
          <text class="record-mood">{{item.moodName}}</text>
          <text class="record-content-preview" wx:if="{{item.content}}">{{item.content}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!todayRecord && monthStats.totalRecords === 0}}">
    <text class="empty-icon">🌸</text>
    <text class="empty-text">还没有任何记录</text>
    <text class="empty-hint">点击上方卡片开始记录你的第一天</text>
  </view>
</view>