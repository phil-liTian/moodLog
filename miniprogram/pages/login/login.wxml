<!--登录页面-->
<view class="page">
  <view class="logo-section">
    <text class="logo">🌸</text>
    <text class="app-name">心情日记</text>
    <text class="app-slogan">记录每一天的心情故事</text>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="input-group">
      <input 
        class="input" 
        placeholder="请输入手机号" 
        type="number"
        maxlength="11"
        bindinput="onPhoneInput"
      />
    </view>
    <view class="input-group">
      <input 
        class="input" 
        placeholder="请输入验证码" 
        type="number"
        maxlength="6"
        bindinput="onCodeInput"
      />
      <view class="code-btn {{canSendCode ? '' : 'disabled'}}" bindtap="sendCode">
        <text>{{codeText}}</text>
      </view>
    </view>
    
    <view class="btn-login" bindtap="login">
      <text>登录</text>
    </view>
  </view>

  <!-- 功能介绍 -->
  <view class="features">
    <view class="feature-item">
      <text class="feature-icon">🔒</text>
      <text class="feature-text">私密安全</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">☁️</text>
      <text class="feature-text">云端同步</text>
    </view>
    <view class="feature-item">
      <text class="feature-icon">🤖</text>
      <text class="feature-text">AI洞察</text>
    </view>
  </view>

  <!-- 暂不登录 -->
  <view class="skip-btn" bindtap="skipLogin">
    <text>暂不登录，仅本地使用</text>
  </view>
</view>